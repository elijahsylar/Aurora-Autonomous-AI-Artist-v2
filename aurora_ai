                self._draw_line(self.x, old_y, self.x, self.y)
        else:
            print(f"  ⚠ WALL — cannot move up from ({self.x},{self.y})")

    def move_down(self):
        """Move drawing position down"""
        if self.y < self.canvas_size - 1:
            old_y = self.y
            self.y = min(self.canvas_size - 1, self.y + 3)
            if self.is_drawing:
                self._draw_line(self.x, old_y, self.x, self.y)
        else:
            print(f"  ⚠ WALL — cannot move down from ({self.x},{self.y})")

