            # Build accurate description from actual executed action
            feedback = ""
            
            if action in '0123':
                position_changed = (self.x != old_x or self.y != old_y)
                direction_map = {
                    '0': ('upward', 'TOP'),
                    '1': ('downward', 'BOTTOM'),
                    '2': ('left', 'LEFT'),
                    '3': ('right', 'RIGHT')
                }
                direction, edge = direction_map.get(action, ('', ''))
                
                if not position_changed:
                    feedback = f"⚠ WALL! I hit the {edge} edge — I CANNOT move {direction}. I am STUCK at ({self.x},{self.y}). I MUST go a DIFFERENT direction."
                elif self.is_drawing:
                    feedback = f"I drew a {self.current_color_name} {self.draw_mode} mark {direction}"
                else:
                    feedback = f"I moved {direction} to ({self.x}, {self.y})"
                
            elif action == '4':
                # Pen lifted
                feedback = "I lifted the pen"
                
            elif action == '5':
                # Pen down
                feedback = f"I put the pen down at ({self.x}, {self.y})"
                
            elif action.startswith('color:'):
                # Color change
                color_name = action.split(':')[1]
                feedback = f"I switched to {color_name}"
                
            elif action == 'star':
                feedback = f"I stamped a {self.current_color_name} star at ({self.x}, {self.y})"
                
            elif action == 'circle':
                feedback = f"I stamped a {self.current_color_name} circle at ({self.x}, {self.y})"
                
