    def _generate_fm_piano(self, freq, sample_rate):
        """Moog-style subtractive synthesis — warm analog pluck.

        Dual detuned sawtooth oscillators through a resonant low-pass
        filter with decaying cutoff. Classic Minimoog bass/lead character.
        """
        duration = 1.4
        samples = int(sample_rate * duration)
        t = np.linspace(0, duration, samples, False)

        # --- Dual sawtooth oscillators (slightly detuned for thickness) ---
        saw1 = 2.0 * (freq * t % 1.0) - 1.0
        saw2 = 2.0 * ((freq * 1.005) * t % 1.0) - 1.0  # +5 cents detune
        output = (saw1 + saw2 * 0.8) * 0.5

        # --- Moog ladder filter (resonant low-pass, cutoff decays) ---
        cutoff_start = min(freq * 8, 12000)
        cutoff_end = min(freq * 1.5, 2000)
        n_chunks = 32
        chunk_size = samples // n_chunks
        filtered = np.zeros(samples)
        for i in range(n_chunks):
            progress = i / n_chunks
            cutoff = cutoff_start * np.exp(-4.0 * progress) + cutoff_end
            cutoff = min(cutoff, sample_rate * 0.45)
            sos = signal.butter(4, cutoff, 'low', fs=sample_rate, output='sos')
            start = i * chunk_size
            end = min(start + chunk_size, samples)
            filtered[start:end] = signal.sosfilt(sos, output[start:end])
        output = filtered

        # --- Amplitude envelope (snappy pluck) ---
        attack_s = int(0.008 * sample_rate)
        decay_s = int(0.15 * sample_rate)
        sus_level = 0.4

        amp_env = np.full(samples, sus_level)
        amp_env[:attack_s] = np.linspace(0.0, 1.0, attack_s)
        if attack_s + decay_s < samples:
            amp_env[attack_s:attack_s + decay_s] = np.linspace(1.0, sus_level, decay_s)
        amp_env *= np.exp(-2.0 * t)
        output *= amp_env

        # --- Soft saturation (analog warmth) ---
        output = np.tanh(output * 1.5) / np.tanh(np.array(1.5))

        # --- Remove DC offset ---
        sos_hp = signal.butter(1, 20.0, 'high', fs=sample_rate, output='sos')
        output = signal.sosfilt(sos_hp, output)

        # --- Normalize ---
        peak = np.max(np.abs(output))
        if peak > 0:
            output /= peak

        return output
    
    def get_closest_color_char(self, r, g, b):
        """Find the closest palette color for mixed/layered colors"""
        min_distance = float('inf')
        closest_color = '*'
        
        # Color to character mapping
        color_chars = {
            'red': 'R', 'orange': 'O', 'yellow': 'Y', 'green': 'G',
            'cyan': 'C', 'blue': 'B', 'purple': 'P', 'pink': 'K',
            'white': 'W', 'gray': '/', 'brown': 'N', 'magenta': 'M',
            'lime': 'L', 'navy': 'V', 'black': 'X'
        }
        
        # Calculate color distance to each palette color
        for color_name, rgb_palette in self.palette.items():
            if color_name == 'eraser':
                continue
            # Euclidean distance in RGB space
            distance = math.sqrt(
                (r - rgb_palette[0])**2 + 
                (g - rgb_palette[1])**2 + 
                (b - rgb_palette[2])**2
            )
            if distance < min_distance:
                min_distance = distance
                closest_color = color_chars.get(color_name, '*')
        
        # If still very far from any palette color, use intensity-based characters
        if min_distance > 100:  # Threshold for "too different"
            brightness = (r + g + b) / 3
            if brightness > 200:
                return '='  # Very bright mixed color
            elif brightness > 150:
                return '+'  # Medium-bright mixed
            elif brightness > 100:
                return '-'  # Medium mixed
            elif brightness > 50:
                return '.'  # Dim mixed
            else:
                return ' '  # Very dark
        
        return closest_color
    
    def get_dominant_color_in_region(self, x, y, sample_size=3):
        """Sample multiple pixels and return the dominant color character"""
        color_votes = {}
        
        for dy in range(-sample_size//2, sample_size//2 + 1):
            for dx in range(-sample_size//2, sample_size//2 + 1):
                px = x + dx
                py = y + dy
                # More defensive bounds checking
                if px >= 0 and py >= 0 and px < self.internal_canvas_size and py < self.internal_canvas_size:
                    try:
                        pixel = self.pixels.getpixel((px, py))
                        if pixel != (0, 0, 0) and pixel != (0, 0, 0, 255):
                            char = self.get_closest_color_char(*pixel[:3])
                            color_votes[char] = color_votes.get(char, 0) + 1
                    except:
                        continue  # Skip any problematic pixels
        
        if color_votes:
            # Return the most common color in the region
            return max(color_votes.items(), key=lambda x: x[1])[0]
        return "."
    
    
