    def capture_thought_process(self, raw_output):
        """Capture Aurora's observation/reasoning before code extraction strips it"""
        
        thought_indicators = [
            "i think", "i see", "i want", "i notice", "i feel",
            "i'm trying", "i should", "i could", "let me",
            "looking at", "the canvas", "my position",
            "what if", "maybe", "perhaps", "interesting",
            "i've been", "i need to", "it looks like",
            "this area", "that color", "i wonder",
            "seeing:", "thought:"
        ]
        
        has_thought = any(indicator in raw_output.lower() for indicator in thought_indicators)
        
        if not has_thought or len(raw_output) < 20:
            return None
        
        # Extract thought portion - everything before action markers
        thought_text = raw_output.strip()
        
        # If there's a SEEING: marker, extract just that section
        if 'seeing:' in thought_text.lower():
            seeing_start = thought_text.lower().find('seeing:') + len('seeing:')
            thought_text = thought_text[seeing_start:]
        elif 'thought:' in thought_text.lower():
            thought_start = thought_text.lower().find('thought:') + len('thought:')
            thought_text = thought_text[thought_start:]
        
        # Cut off at action markers
        action_markers = ['doing:', 'codes:', 'cods:', 'codls:', 'codles:', 'comds:', 
                         'comands:', 'commands:', 'cmds:', 'actions:']
        for marker in action_markers:
            if marker in thought_text.lower():
                thought_text = thought_text[:thought_text.lower().find(marker)]
                break
        
        # Clean up
        thought_text = thought_text.replace('\n', ' ').strip()
        if len(thought_text) > 500:
            thought_text = thought_text[:500] + "..."
        
        if len(thought_text) < 10:
            return None
        
        # Filter out assistant-mode responses and template-lock phrases
        assistant_patterns = ["certainly!", "great!", "here are", "based on your", 
                            "let's get started", "i hope you",
                            "i see a blank canvas", "blank canvas in front of me",
                            "blank canvas with dimensions", "blank canvas with a grid",
                            "as an ai language model", "i don't have the ability",
                            "as the ai, i see a blank"]
        if any(pattern in thought_text.lower() for pattern in assistant_patterns):
            return None
        
        print(f"\n    Aurora SEES: \"{thought_text}\"")
        
        def _is_negated(text, match_start):
            """Return True if the word 'not', 'no', or "don't/doesn't/didn't" appears
            within 5 words before this match position."""
            snippet = text[max(0, match_start - 40):match_start].lower()
            return bool(re.search(r"\b(not|no|don't|dont|doesn't|doesnt|didn't|didnt|never)\s+\w*\s*$", snippet))

        # Extract "feel a sense of X" — specific pattern, takes priority
        _emotion_captured = False
        sense_match = re.search(r'\bfeel\s+a\s+sense\s+of\s+(\w+)', raw_output.lower())
        if sense_match:
            word = sense_match.group(1)
            if word not in self._not_emotions() and not _is_negated(raw_output.lower(), sense_match.start()):
                old_emotion = self.current_emotion
                if word != old_emotion:
                    self.current_emotion = word
                    print(f"    Aurora self-reports feeling: {word}")
                    if self.research:
                        self.research.log_emotion_shift(
                            old_emotion, word,
                            trigger_source="self_reported",
                            step=self.steps_taken
                        )
                    if hasattr(self, 'db') and self.db:
                        self.db.save_emotion_shift(
                            step=self.steps_taken,
                            new_emotion=word,
                            prev_emotion=old_emotion
                        )
                _emotion_captured = True
        
        # Extract self-reported emotion from "I feel X" / "I'm feeling X"
        # Use finditer to check ALL matches (first may be "feel a", "feel like", etc.)
        # Skip if we already captured from "sense of" above
        if not _emotion_captured:
            for feel_match in re.finditer(r'\bfeel(?:ing)?\s+(\w+)', raw_output.lower()):
                word = feel_match.group(1)
                if word not in self._not_emotions() and not _is_negated(raw_output.lower(), feel_match.start()):
                    old_emotion = self.current_emotion
                    if word != old_emotion:
                        self.current_emotion = word
                        print(f"    Aurora self-reports feeling: {word}")
                        if self.research:
                            self.research.log_emotion_shift(
                                old_emotion, word,
                                trigger_source="self_reported",
                                step=self.steps_taken
                            )
                        if hasattr(self, 'db') and self.db:
                            self.db.save_emotion_shift(
                                step=self.steps_taken,
                                new_emotion=word,
                                prev_emotion=old_emotion
                            )
                    break  # Use first valid emotion found
        
        thought_record = {
            'step': self.steps_taken,
            'thought': thought_text,
            'emotion': self.current_emotion,
            'position': (self.x, self.y),
            'timestamp': time.time()
        }
        
        # Log thought to research pipeline
        if self.research:
            self.research.log_thought(
                step=self.steps_taken,
                thought_text=thought_text,
                emotional_state=self.current_emotion,
                position=(self.x, self.y),
                pen_down=self.is_drawing,
                current_tool=self.draw_mode,
                current_color=self.current_color_name
            )
        
        if not hasattr(self, 'thought_history'):
            self.thought_history = deque(maxlen=200)
        self.thought_history.append(thought_record)

        # Write to DB live
        if hasattr(self, 'db') and self.db:
            self.db.save_thought(
                step=self.steps_taken,
                thought=thought_text,
                emotion=self.current_emotion,
                x=self.x,
                y=self.y
            )

        if len(self.thought_history) % 10 == 0:
            self._save_thoughts()
        
        return thought_record
    
