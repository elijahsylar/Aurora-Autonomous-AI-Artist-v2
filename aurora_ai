# ===== MODEL-AWARE THINKING TOKEN DETECTION =====
# Each model has its own "I'm still thinking" signals that should NOT be executed
THINKING_TOKENS = {
    "llama2":    {"???"},
    "llama":     {"???"},
    "deepseek":  {"<", "</", "</>", "</think>", "<think>", "</s>"},
}

def is_thinking_signal(signal_text, model_key):
    """Return True if the signal is just the model reasoning, not an action."""
    cleaned = signal_text.strip()
    for key, tokens in THINKING_TOKENS.items():
        if key in model_key.lower():
            return cleaned in tokens
    return False

def strip_think_blocks(text, model_key):
    """Remove DeepSeek-style <think>...</think> blocks before parsing."""
    if "deepseek" in model_key.lower():
        # Remove fully closed think blocks
        text = re.sub(r'<think>.*?</think>', '', text, flags=re.DOTALL)
        # Remove orphaned opening tag (model still mid-thought, block never closed)
        text = re.sub(r'<think>.*$', '', text, flags=re.DOTALL)
    return text.strip()

