    def record_creative_experience(self, actions_taken, pixels_drawn, context):
        """Record what Aurora did without judging quality - learning happens in dreams
        
        This replaces the old update_skill_proficiency which scored "good" vs "bad" art
        and pushed Aurora toward conventional/optimal choices. Instead, we just record
        the raw experience and let dream consolidation find meaning.
        """
        # Extract raw data about what happened
        colors_used = [a.split(':')[1] for a in actions_taken if a.startswith('color:')]
        movements = [a for a in actions_taken if a in '0123']
        tools_used = context.get('draw_mode', 'pen')
        
        # Track area exploration (novelty is about curiosity, not quality)
        grid_x = self.x // 50
        grid_y = self.y // 50
        area_key = (grid_x, grid_y)
        
        if not hasattr(self, 'areas_explored'):
            self.areas_explored = set()
        is_new_area = area_key not in self.areas_explored
        self.areas_explored.add(area_key)
        
        # Track color exploration (not harmony - just what she's tried)
        if not hasattr(self, 'colors_explored_this_session'):
            self.colors_explored_this_session = set()
        new_colors = set(colors_used) - self.colors_explored_this_session
        self.colors_explored_this_session.update(colors_used)
        
        # Track tool exploration
        if not hasattr(self, 'tools_explored_this_session'):
            self.tools_explored_this_session = set()
        is_new_tool = tools_used not in self.tools_explored_this_session
        self.tools_explored_this_session.add(tools_used)
        
        # Build experience record - raw data, no scores
        experience = {
            'step': self.steps_taken,
            'actions': actions_taken,
            'pixels_drawn': pixels_drawn,
            'colors_used': colors_used,
            'movement_sequence': ''.join(movements),
            'tool': tools_used,
            'emotion': self.current_emotion,
            'emotion_category': getattr(self, 'emotion_category', 'neutral'),
            'position': (self.x, self.y),
            'area': context.get('area', self._get_canvas_area(self.x, self.y)),
            'canvas_density': context.get('canvas_density', self.calculate_current_coverage() / 100.0),
            'explored_new_area': is_new_area,
            'explored_new_colors': list(new_colors),
            'explored_new_tool': is_new_tool,
            'timestamp': time.time()
        }
        
        # Store for dream processing - no immediate reward/punishment
        self.learning_experiences.append(experience)
        
        # Store pattern context for associative memory (if meaningful pattern)
        movement_sequence = ''.join(movements)
        if len(movement_sequence) >= 6:
            self.artistic_associations['pattern_contexts'].append({
                'pattern': movement_sequence[:20],  # First 20 chars
                'emotion': self.current_emotion,
                'colors_used': colors_used[:3],
                'area': experience['area'],
                'tool': tools_used,
                'timestamp': time.time()
            })
            # Keep rolling window
            if len(self.artistic_associations['pattern_contexts']) > 300:
                self.artistic_associations['pattern_contexts'] = self.artistic_associations['pattern_contexts'][-300:]
        
        # Store tool context
        if is_new_tool or self.steps_taken % 50 == 0:
            self.artistic_associations['tool_contexts'].append({
                'tool': tools_used,
                'emotion': self.current_emotion,
                'canvas_density': experience['canvas_density'],
                'area': experience['area'],
                'timestamp': time.time()
            })
            if len(self.artistic_associations['tool_contexts']) > 200:
                self.artistic_associations['tool_contexts'] = self.artistic_associations['tool_contexts'][-200:]
        
        # Periodic logging (less frequent, just informational)
        if self.steps_taken % 100 == 0:
            total_areas = len(self.areas_explored)
            total_colors = len(self.colors_explored_this_session)
            print(f"   [Experience: {total_areas} areas explored, {total_colors} colors tried]")
        
                   
    def evaluate_personal_satisfaction(self, actions_taken, pixels_drawn):
        """Aurora observes what she created - NO SCORING
        
        This method now only observes and records, without computing satisfaction
        scores that would drive behavior toward optimizing for rewards.
        The name is kept for backwards compatibility but behavior is changed.
        """
        # Extract what happened (observation only)
        colors_used = [a.split(':')[1] for a in actions_taken if a.startswith('color:')]
        action_sequence = ''.join([a for a in actions_taken if a in '0123'])
        
        # Record technique discovery based on novelty, not satisfaction
        if len(action_sequence) >= 8:
            # Check if this is a genuinely new pattern
            pattern_hash = hash(action_sequence[:12])
            known_patterns = [hash(t.get('pattern', '')[:12]) for t in self.artistic_associations.get('technique_discoveries', [])]
            
            if pattern_hash not in known_patterns:
                # New technique discovered - record it with context, not score
                self.artistic_associations['technique_discoveries'].append({
                    'pattern': action_sequence[:20],
                    'discovery_emotion': self.current_emotion,
                    'colors_at_discovery': colors_used[:3],
                    'canvas_density': self.calculate_current_coverage() / 100.0,
                    'tool_used': self.draw_mode,
                    'timestamp': datetime.now().isoformat()
                })
                
                # Keep rolling window
                if len(self.artistic_associations['technique_discoveries']) > 100:
                    self.artistic_associations['technique_discoveries'] = self.artistic_associations['technique_discoveries'][-100:]
                
                if self.steps_taken % 50 == 0:  # Only announce occasionally
                    print(f"   Aurora discovered a new technique while feeling {self.current_emotion}")
        
        # Save associations periodically (not preferences with scores)
        if self.steps_taken % 50 == 0:
