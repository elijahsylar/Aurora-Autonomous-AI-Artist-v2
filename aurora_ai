    def generate_dream(self):
        """Dream system with three distinct phases:
        
        Light sleep (0-5 min):  Quiet rest, housekeeping
        REM (5-15 min):         Creative hallucination — LLM runs free
        Waking (15-20 min):     Extract vague dream fragments
        """
        elapsed = time.time() - self.mode_start_time

        if self.sleep_phase == "light":
            # Light sleep: quiet rest, one-time housekeeping
            if not getattr(self, '_light_sleep_done', False):
                self._light_sleep_done = True
                print(f"\n  💤 Aurora drifts into light sleep...")
                self.save_canvas_state()
                self.memory.save_memories()
            return

        elif self.sleep_phase == "rem":
            # REM: creative hallucination — generate multiple dreams
            # One dream every ~2 minutes, max 5 dreams
            dreams_expected = min(5, int((elapsed - 300) / 120) + 1)
            rem_dreams = [d for d in self.current_dreams if d.get('phase') == 'rem']

            if len(rem_dreams) >= dreams_expected:
                return  # Already generated enough for this point in REM

            print(f"\n  🌙 Aurora enters REM dream #{len(rem_dreams) + 1}...")
            self._generate_rem_dream(len(rem_dreams) + 1)

        elif self.sleep_phase == "waking":
            # Waking: extract fragments from REM dreams
            if not getattr(self, '_wake_fragments_extracted', False):
                self._wake_fragments_extracted = True
                self._extract_dream_fragments()

    def _generate_rem_dream(self, dream_number):
        """REM dreaming: let the LLM think freely. No seeds. No instructions. No constraints."""
        
        system_prompt = """I am dreaming. I can think freely about whatever I'd like to."""

        user_prompt = "Dream..."

        full_prompt = self._format_prompt(system_prompt, user_prompt)

        try:
            response = self.llm(
                full_prompt,
                max_tokens=300,
                temperature=1.3,
                top_p=0.98,
                top_k=100,
                stop=self._get_stop_tokens(),
                stream=False
            )

            dream_text = response['choices'][0]['text'].strip()
            
            if dream_text:
                print(f"\n    💭 Dream #{dream_number}:")
                print(f"    {dream_text[:200]}{'...' if len(dream_text) > 200 else ''}")
                
                self.current_dreams.append({
                    "phase": "rem",
                    "dream_number": dream_number,
                    "content": dream_text,
                    "timestamp": datetime.now().isoformat()
                })

                self.dream_count += 1

                # Save to DB
                if hasattr(self, 'db') and self.db:
                    try:
                        self.db.log_dream(
                            dream_number=dream_number,
                            content=dream_text,
                            sleep_phase="rem",
                            time_into_rest=time.time() - self.mode_start_time
                        )
                    except Exception as e:
                        print(f"    [DB] Dream save failed: {e}")

                # Research logger
                if hasattr(self, 'research') and self.research:
                    try:
                        self.research.log_dream(
                            sleep_phase="rem",
                            dream_content=dream_text,
                            emotions_referenced=[],
                            time_into_rest_sec=time.time() - self.mode_start_time
                        )
                    except Exception:
                        pass

        except Exception as e:
            print(f"    Dream faded... ({e})")

    def _extract_dream_fragments(self):
        """Waking phase: programmatically extract short fragments from REM dreams.
        No LLM call — just parse the raw dream text for short, evocative phrases.
        """
        rem_dreams = [d for d in self.current_dreams if d.get('phase') == 'rem']
        
        if not rem_dreams:
            print("    Aurora wakes with no dream memories...")
            self.dream_fragments = []
            self.process_dream_retention()
            return
        
        fragments = []
        for dream in rem_dreams:
            content = dream.get('content', '')
            if not content:
                continue
            
            # Split into sentences
            sentences = []
            for sep in ['. ', '! ', '? ', '.\n', '!\n', '?\n']:
                content = content.replace(sep, '.|.')
            raw_sentences = content.split('.|.')
            
            for s in raw_sentences:
                s = s.strip().strip('.').strip()
                word_count = len(s.split())
                # Keep short evocative fragments (4-15 words)
                if 4 <= word_count <= 15 and s:
                    sentences.append(s)
            
            # Pick one random short fragment from this dream
            if sentences:
                fragments.append(random.choice(sentences))
        
        # Keep max 3 fragments
        self.dream_fragments = fragments[:3]
        
        if self.dream_fragments:
            print(f"\n    🌅 Aurora wakes with dream echoes:")
            for frag in self.dream_fragments:
                print(f"      \"{frag}\"")
        else:
            print(f"\n    🌅 Aurora wakes... dreams already fading...")
            self.dream_fragments = []
        
        # Save all dreams to memory
        self.process_dream_retention()
    
    def process_dream_retention(self):
        """Consolidate learned insights from dreams into long-term memory"""
        if not self.current_dreams:
            return
        
        consolidated_learning = {
            "session_id": datetime.now().strftime("%Y%m%d_%H%M%S"),
            "patterns_reinforced": [],
            "skills_improved": [],
            "insights_gained": [],
            "timestamp": datetime.now().isoformat()
        }
        
        for dream in self.current_dreams:
            consolidation = dream.get('consolidation', {})
            
            # Handle REM dreams (creative LLM-generated content)
            if dream.get('phase') == 'rem' and dream.get('content'):
                consolidated_learning['insights_gained'].append(dream['content'][:200])
                continue
            
            # NEW: Handle comprehensive consolidation type
            if consolidation.get('type') == 'comprehensive':
                insights = consolidation.get('insights', [])
                skills = consolidation.get('skills', [])
                consolidated_learning['insights_gained'].extend(insights)
                consolidated_learning['skills_improved'].extend(skills)
            
            elif consolidation.get('type') == 'pattern_reinforcement':
                pattern = consolidation.get('pattern', '')
                if pattern:
                    consolidated_learning['patterns_reinforced'].append({
                        'pattern': pattern,
                        'success_metric': consolidation.get('success_metric', 0)
                    })
            
            elif consolidation.get('type') == 'skill_integration':
                skills = consolidation.get('skills', [])
                insights = consolidation.get('insights', [])
                consolidated_learning['skills_improved'].extend(skills)
                consolidated_learning['insights_gained'].extend(insights)
            
            elif consolidation.get('type') == 'action_plan':
                actions = consolidation.get('next_actions', [])
                consolidated_learning['insights_gained'].extend(actions)
        
        # Save consolidated learning to dedicated file
        learning_file = self.memory.memory_path / "consolidated_learning.json"
        
        existing_learning = []
        if learning_file.exists():
            try:
                with open(learning_file, 'r') as f:
                    existing_learning = json.load(f)
            except:
                existing_learning = []
        
        existing_learning.append(consolidated_learning)
        
        # Keep only last 50 consolidations
        if len(existing_learning) > 50:
            existing_learning = existing_learning[-50:]
        
        with open(learning_file, 'w') as f:
            json.dump(existing_learning, f, indent=2)
        
        print(f"   Consolidated learning saved: {len(consolidated_learning['patterns_reinforced'])} patterns, {len(set(consolidated_learning['skills_improved']))} skills, {len(consolidated_learning['insights_gained'])} insights")
        
        # Sync to deep memory after dream consolidation
