    def _get_canvas_area(self, x, y):
        """Determine which area of the canvas a position is in"""
        mid_x = self.canvas_size // 2
        mid_y = self.canvas_size // 2
        center_threshold = self.canvas_size // 6
        
        if abs(x - mid_x) < center_threshold and abs(y - mid_y) < center_threshold:
            return "center"
        elif x < mid_x and y < mid_y:
            return "top-left"
        elif x >= mid_x and y < mid_y:
            return "top-right"
        elif x < mid_x and y >= mid_y:
            return "bottom-left"
        else:
            return "bottom-right"
    
    def reflect_on_recent_work(self):
        """Aurora describes what she made - no scoring, just observation
        
        This is associative memory without reward. Aurora builds self-awareness
        through description, not through optimization.
        """
        recent = list(self.memory.code_history)[-10:]
        if not recent:
            return None
            
        colors_used = [r.get('context', {}).get('color', 'unknown') for r in recent]
        areas_visited = [r.get('context', {}).get('area', 'unknown') for r in recent]
        emotions_felt = [r.get('context', {}).get('emotion_during', 'neutral') for r in recent]
        
        # Count unique elements
        unique_colors = list(set([c for c in colors_used if c]))
        unique_areas = list(set([a for a in areas_visited if a]))
        unique_emotions = list(set([e for e in emotions_felt if e]))
        
        system = f"""I just made marks on my canvas.
I used {', '.join(unique_colors[:5]) if unique_colors else 'various colors'}. I visited {', '.join(unique_areas) if unique_areas else 'various areas'}.
My canvas is {self.calculate_current_coverage():.0f}% filled."""
        
        try:
            full_prompt = self._format_prompt(system, "What do I notice?") + "I"
            response = self.llm(full_prompt, max_tokens=40, temperature=0.9, stop=self._get_stop_tokens() + ["\n\n"])
            description = "I" + response['choices'][0]['text'].strip()
            
            if description:
                # Store description with recent memories
                for memory in recent:
                    if memory.get('context', {}).get('description') is None:
                        memory['context']['description'] = description
                        break
                
                # Store as emotional moment
                self.artistic_associations['emotional_moments'].append({
                    'emotion': self.current_emotion,
                    'description': description,
                    'colors_active': unique_colors[:3],
                    'canvas_density': self.calculate_current_coverage() / 100.0,
                    'areas': unique_areas,
                    'timestamp': time.time()
                })
                
                # Keep rolling window
                if len(self.artistic_associations['emotional_moments']) > 200:
                    self.artistic_associations['emotional_moments'] = self.artistic_associations['emotional_moments'][-200:]
                
                self.last_reflection = description
                print(f"   Aurora reflects: {description}")
                
                return description
        except Exception as e:
            print(f"   Reflection error: {e}")
        
        return None
    
    def check_for_repetition_drift(self):
        """Repetition naturally shifts emotion toward restless/curious
        
        This is not punishment for repetition - it's natural boredom.
        The emotion change then organically produces different outputs.
        """
        if not hasattr(self, 'color_history') or len(self.color_history) < 20:
            return
            
        recent_colors = list(self.color_history)[-20:]
        recent_patterns = [m.get('code', '')[:5] for m in list(self.memory.code_history)[-20:] if m.get('code')]
        
        # Count repetition
        color_repetition = len(recent_colors) - len(set(recent_colors))
        pattern_repetition = len(recent_patterns) - len(set(recent_patterns))
        
        repetition_score = (color_repetition + pattern_repetition) / 40.0
        
        if repetition_score > 0.5:
            # High repetition → drift toward curiosity/energy
            # This is not a penalty, just natural restlessness
            if self.emotion_category in ["peace", "contemplation", "melancholy"]:
                old_category = self.emotion_category
                self.emotion_category = "curiosity"
                self.emotion_depth = min(self.emotion_depth + 1, 4)
                
                # Update current_emotion word from the new category
                emotions_in_category = self.deep_emotions.get(self.emotion_category, ["base"])
                self.current_emotion = emotions_in_category[min(self.emotion_depth, len(emotions_in_category)-1)]
                
                if self.steps_taken % 100 == 0:  # Only print occasionally
                    print(f"   Restlessness emerging... ({old_category} → {self.emotion_category})")
    
    def recall_similar_context(self):
        """Find memories from similar emotional/canvas states
        
        Recall by association, not by score. What did Aurora do
        when she felt this way before? When the canvas looked like this?
        """
        similar = []
        current_density = self.calculate_current_coverage() / 100.0
        
        for memory in self.memory.code_history:
            ctx = memory.get('context', {})
            
            # Match by emotion
            if ctx.get('emotion_during') == self.current_emotion:
                similar.append(memory)
            
            # Match by canvas density (within 10%)
            mem_density = ctx.get('canvas_density', 0)
            if abs(mem_density - current_density) < 0.1:
                similar.append(memory)
            
            # Match by area
            if ctx.get('area') == self._get_canvas_area(self.x, self.y):
                similar.append(memory)
        
        # Remove duplicates while preserving order
        seen = set()
        unique_similar = []
        for m in similar:
            m_id = id(m)
            if m_id not in seen:
                seen.add(m_id)
                unique_similar.append(m)
        
        return unique_similar[-5:]  # Return most recent similar contexts
    
